# Codex CLI auth
# This MVP uses your local Codex CLI session first.
# Check it with:
#   codex.cmd login status
#
# If you choose API-key login later, never commit the real key:
#   OPENAI_API_KEY=sk-...

# Claude Code currently needs either enabled subscription access or an API key.
#   ANTHROPIC_API_KEY=sk-ant-...

# Gemini CLI needs one configured auth method.
#   GEMINI_API_KEY=...
