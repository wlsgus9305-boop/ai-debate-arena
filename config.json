{
  "game": {
    "mode": "debate",
    "rounds": 1,
    "maxDays": 3,
    "dayRounds": 1,
    "firstDayExecution": false,
    "responseEndToken": "<<<END>>>",
    "turnTimeoutMs": 180000,
    "maxSpeechChars": 900,
    "publicLogPath": "logs/public_log.md",
    "privateLogDir": "logs/private",
    "roles": {
      "mafia": 1,
      "police": 1,
      "doctor": 1
    },
    "interrupt": {
      "enabled": true,
      "chance": 0.65
    },
    "spectatorRevealRoles": true,
    "namePool": [
      "알파",
      "브라보",
      "찰리",
      "델타",
      "에코",
      "폭스트롯",
      "루나",
      "오리온",
      "제타",
      "카이",
      "노바",
      "세이지"
    ]
  },
  "providers": {
    "codex": {
      "command": "codex",
      "label": "Codex",
      "color": "#6fb1ff",
      "account": "",
      "note": "Codex uses the local authenticated ChatGPT/Codex session.",
      "model": {
        "insertAfter": "exec",
        "args": ["--model", "{model}"],
        "presets": ["", "gpt-5-codex", "gpt-5.2-codex", "gpt-5.3-codex", "codex-mini-latest"]
      },
      "args": [
        "--ask-for-approval",
        "never",
        "exec",
        "--skip-git-repo-check",
        "--ephemeral",
        "--sandbox",
        "read-only",
        "--output-last-message",
        "{output_file}",
        "-"
      ]
    },
    "claude": {
      "command": "claude",
      "label": "Claude",
      "color": "#d69f68",
      "account": "",
      "note": "Claude Code uses the local authenticated Claude Code session only.",
      "model": {
        "insertAt": "start",
        "args": ["--model", "{model}"],
        "presets": ["", "sonnet", "opus", "claude-sonnet-4-20250514"]
      },
      "args": [
        "-p",
        "--permission-mode",
        "dontAsk",
        "--tools",
        "",
        "--output-format",
        "text",
        "--no-session-persistence"
      ]
    },
    "gemini": {
      "command": "npx",
      "label": "Gemini",
      "color": "#9f87ff",
      "account": "",
      "note": "Gemini runs through npx @google/gemini-cli and uses local Gemini CLI auth only.",
      "model": {
        "insertAfter": "@google/gemini-cli",
        "args": ["-m", "{model}"],
        "presets": ["", "gemini-2.5-pro", "gemini-2.5-flash"]
      },
      "args": [
        "--yes",
        "@google/gemini-cli",
        "-p",
        "",
        "--approval-mode",
        "plan",
        "--output-format",
        "text",
        "--skip-trust"
      ]
    }
  },
  "integrations": [
    {
      "id": "grok",
      "label": "Grok",
      "status": "planned",
      "account": "",
      "note": "Grok CLI or local agent adapter candidate.",
      "setup": "공식 CLI나 로컬 agent 실행 방식이 확정되면 provider adapter를 추가해 연결할 수 있습니다."
    },
    {
      "id": "cursor",
      "label": "Cursor",
      "status": "planned",
      "account": "",
      "note": "Cursor agent or IDE session adapter candidate.",
      "setup": "Cursor CLI/Agent 자동화 방식이 확정되면 이 연결 목록에서 활성화할 수 있습니다."
    }
  ],
  "moderator": {
    "id": "moderator",
    "displayName": "회의 진행자",
    "provider": "codex",
    "enabled": true,
    "workdir": "agents/moderator",
    "model": "",
    "color": "#e4b84a",
    "personality": "토론의 열기를 살리면서 논점 이탈을 잡고, 라운드 끝마다 선택지와 다음 질문을 좁히는 진행자."
  },
  "players": [
    {
      "id": "gpt_1",
      "displayName": "알파",
      "provider": "codex",
      "enabled": true,
      "workdir": "agents/gpt_1",
      "model": "",
      "color": "#f59e0b",
      "personality": "차분한 논리파. 감정 표현은 적지만 말의 모순을 끝까지 물고 늘어진다."
    },
    {
      "id": "claude_1",
